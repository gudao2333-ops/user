{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://djapi.gudao.one/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://djapi.gudao.one/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
